{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "score": {
      "type": "integer",
      "description": "Relevance score from 0 (no fit) through 100 (strong fit), inclusive. Must be an integer."
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["score", "rationale"],
  "additionalProperties": false
}
